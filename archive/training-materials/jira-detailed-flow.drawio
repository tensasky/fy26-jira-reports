<mxfile host="app.diagrams.net" modified="2026-02-13T03:00:00.000Z" agent="OpenClaw" etag="jira-detailed-flow" version="22.1.0" type="device">
  <diagram name="Jira项目管理详细流程" id="jira-project-flow">
    <mxGraphModel dx="1682" dy="1014" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- 标题 -->
        <mxCell id="title" value="&lt;b style=&quot;font-size: 18px;&quot;&gt;🎯 Jira 项目管理标准实施流程&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;基于Jira Best Practice的可落地执行流程&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="450" y="10" width="500" height="40" as="geometry" />
        </mxCell>
        
        <!-- ========== 阶段1: 项目启动 ========== -->
        <mxCell id="phase1-header" value="&lt;b&gt;阶段一：项目启动&lt;/b&gt;&lt;br&gt;Project Initiation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4CAF50;strokeColor=#2E7D32;fontColor=#ffffff;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="200" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="phase1-epic" value="&lt;b&gt;📋 Jira: 创建Epic&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 路径: Backlog → Create Issue → Epic&lt;br&gt;• 标题: [里程碑]-[功能]-[目标]&lt;br&gt;• 必填字段:&lt;br&gt;  - 开始/结束日期&lt;br&gt;  - Business Value (1-5)&lt;br&gt;  - Risk Level&lt;br&gt;  - 业务目标和成功标准&lt;br&gt;&lt;br&gt;✅ 质量标准:&lt;br&gt;• 有明确业务目标&lt;br&gt;• 可衡量的成功标准&lt;br&gt;• 工作量≤2个Sprint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="130" width="280" height="220" as="geometry" />
        </mxCell>
        
        <mxCell id="phase1-config" value="&lt;b&gt;⚙️ Jira: 项目配置&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 创建项目 (Scrum/Kanban)&lt;br&gt;• 配置问题类型&lt;br&gt;  - Epic, Story, Task, Bug&lt;br&gt;  - Spike, Sub-task&lt;br&gt;• 配置工作流&lt;br&gt;• 设置自定义字段&lt;br&gt;• 配置权限和通知&lt;br&gt;• 创建组件和版本&lt;br&gt;&lt;br&gt;✅ 交付物:&lt;br&gt;• 完整的Jira项目&lt;br&gt;• 配置文档" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="130" width="250" height="220" as="geometry" />
        </mxCell>
        
        <!-- ========== 阶段2: 需求分析 ========== -->
        <mxCell id="phase2-header" value="&lt;b&gt;阶段二：需求分析与规划&lt;/b&gt;&lt;br&gt;Requirement Analysis &amp;amp; Planning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9C27B0;strokeColor=#6A1B9A;fontColor=#ffffff;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="50" y="370" width="280" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="phase2-story" value="&lt;b&gt;📝 Jira: 创建用户故事&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 在Epic下创建Story&lt;br&gt;• 标题格式:&lt;br&gt;  作为[角色],我想要[功能],以便[价值]&lt;br&gt;• 必填字段:&lt;br&gt;  - Story Points (1,2,3,5,8)&lt;br&gt;  - Acceptance Criteria&lt;br&gt;  - Sprint&lt;br&gt;  - Assignee&lt;br&gt;&lt;br&gt;✅ 质量标准:&lt;br&gt;• 关联Epic&lt;br&gt;• 3+可测试验收标准&lt;br&gt;• Points≤8 (否则拆分)&lt;br&gt;• 说明业务价值" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9C27B0;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="430" width="280" height="240" as="geometry" />
        </mxCell>
        
        <mxCell id="phase2-sprint" value="&lt;b&gt;🎯 Jira: Sprint规划&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 创建Sprint&lt;br&gt;  名称: Sprint [编号]-[目标]&lt;br&gt;• 设置Duration (通常2周)&lt;br&gt;• 定义Sprint Goal&lt;br&gt;• 容量计算:&lt;br&gt;  人数×10天×6小时×0.8&lt;br&gt;• 选择Story进入Sprint&lt;br&gt;• 分配任务&lt;br&gt;&lt;br&gt;✅ 质量标准:&lt;br&gt;• Goal明确且可衡量&lt;br&gt;• 工作量≤团队容量&lt;br&gt;• 预留20% Buffer&lt;br&gt;• 所有Story有验收标准" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9C27B0;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="430" width="260" height="240" as="geometry" />
        </mxCell>
        
        <mxCell id="phase2-task" value="&lt;b&gt;🔧 Jira: Task分解&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Story分解为Sub-task&lt;br&gt;• Task类型:&lt;br&gt;  - [DEV] 开发任务&lt;br&gt;  - [DESIGN] 设计任务&lt;br&gt;  - [TEST] 测试任务&lt;br&gt;  - [DOC] 文档任务&lt;br&gt;• 必填字段:&lt;br&gt;  - Estimated Hours&lt;br&gt;  - Assignee&lt;br&gt;  - 验收标准&lt;br&gt;&lt;br&gt;✅ 质量标准:&lt;br&gt;• 每个Task≤8小时&lt;br&gt;• 有明确验收标准&lt;br&gt;• 标注任务类型&lt;br&gt;• 指定负责人" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9C27B0;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="630" y="430" width="240" height="240" as="geometry" />
        </mxCell>
        
        <!-- ========== 阶段3: 开发执行 ========== -->
        <mxCell id="phase3-header" value="&lt;b&gt;阶段三：开发执行&lt;/b&gt;&lt;br&gt;Development Execution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9800;strokeColor=#E65100;fontColor=#ffffff;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="50" y="690" width="200" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="phase3-dev" value="&lt;b&gt;💻 Jira: 开发工作流&lt;/b&gt;&lt;br&gt;&lt;br&gt;• To Do → In Progress&lt;br&gt;• 创建分支:&lt;br&gt;  feature/PROJ-123-description&lt;br&gt;• Commit规范:&lt;br&gt;  PROJ-123 feat: description&lt;br&gt;• 提交PR&lt;br&gt;• Jira添加PR链接&lt;br&gt;• In Progress → Code Review&lt;br&gt;&lt;br&gt;✅ 质量门禁:&lt;br&gt;• 通过CI检查&lt;br&gt;• 单元测试≥80%&lt;br&gt;• 无安全漏洞&lt;br&gt;• Code Review通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="750" width="260" height="230" as="geometry" />
        </mxCell>
        
        <mxCell id="phase3-cr" value="&lt;b&gt;👀 Jira: Code Review&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Review检查项:&lt;br&gt;  □ 代码规范&lt;br&gt;  □ 单元测试&lt;br&gt;  □ 性能问题&lt;br&gt;  □ 安全漏洞&lt;br&gt;  □ 日志处理&lt;br&gt;  □ 设计模式&lt;br&gt;• PR评论回复&lt;br&gt;• Review通过后:&lt;br&gt;  Code Review → Testing&lt;br&gt;&lt;br&gt;✅ 质量标准:&lt;br&gt;• 100%代码审查&lt;br&gt;• 所有评论解决&lt;br&gt;• 通过自动化测试" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="750" width="230" height="230" as="geometry" />
        </mxCell>
        
        <!-- ========== 阶段4: 测试QA ========== -->
        <mxCell id="phase4-header" value="&lt;b&gt;阶段四：测试与质量控制&lt;/b&gt;&lt;br&gt;Testing &amp;amp; QA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00BCD4;strokeColor=#00838F;fontColor=#ffffff;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="620" y="70" width="280" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="phase4-test" value="&lt;b&gt;🧪 Jira: 测试执行&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 编写测试用例&lt;br&gt;  关联到Story&lt;br&gt;• 执行测试&lt;br&gt;• Testing状态验证&lt;br&gt;• 通过 → Done&lt;br&gt;• 失败 → 创建Bug&lt;br&gt;&lt;br&gt;✅ 质量标准:&lt;br&gt;• 测试用例覆盖所有Story&lt;br&gt;• 单元测试≥80%&lt;br&gt;• 集成测试通过&lt;br&gt;• Bug严重程度分类" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F7FA;strokeColor=#00BCD4;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="130" width="240" height="200" as="geometry" />
        </mxCell>
        
        <mxCell id="phase4-bug" value="&lt;b&gt;🐛 Jira: Bug管理&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Bug创建规范:&lt;br&gt;  - 重现步骤&lt;br&gt;  - 期望/实际结果&lt;br&gt;  - 环境信息&lt;br&gt;  - 严重程度&lt;br&gt;    * Blocker: 4h修复&lt;br&gt;    * Critical: 24h修复&lt;br&gt;    * Major: 3天修复&lt;br&gt;• 工作流:&lt;br&gt;  Open→Confirmed→In Progress→Fixed→Verified→Closed&lt;br&gt;&lt;br&gt;✅ 质量门禁:&lt;br&gt;• 严重Bug清零&lt;br&gt;• 所有Bug已验证" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F7FA;strokeColor=#00BCD4;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="880" y="130" width="260" height="200" as="geometry" />
        </mxCell>
        
        <!-- ========== 阶段5: 发布收尾 ========== -->
        <mxCell id="phase5-header" value="&lt;b&gt;阶段五：发布与收尾&lt;/b&gt;&lt;br&gt;Release &amp;amp; Closure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#795548;strokeColor=#4E342E;fontColor=#ffffff;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="900" y="370" width="240" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="phase5-release" value="&lt;b&gt;🚀 Jira: 版本发布&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 创建版本&lt;br&gt;  命名: v[主].[功能].[补丁]&lt;br&gt;• 关联完成的Issues&lt;br&gt;• 编写Release Notes&lt;br&gt;  - 新功能&lt;br&gt;  - Bug修复&lt;br&gt;  - 已知问题&lt;br&gt;• 发布检查清单&lt;br&gt;  □ 所有功能完成&lt;br&gt;  □ Bug清零&lt;br&gt;  □ 文档更新&lt;br&gt;  □ 回滚方案&lt;br&gt;• 标记Released" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFEBE9;strokeColor=#795548;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="900" y="430" width="240" height="240" as="geometry" />
        </mxCell>
        
        <mxCell id="phase5-retro" value="&lt;b&gt;📊 Jira: Sprint回顾&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 数据收集:&lt;br&gt;  - Sprint Report&lt;br&gt;  - Velocity Chart&lt;br&gt;  - Burndown Chart&lt;br&gt;• 回顾会议:&lt;br&gt;  - 做得好的&lt;br&gt;  - 需改进的&lt;br&gt;  - 行动计划&lt;br&gt;• 关闭Sprint&lt;br&gt;&lt;br&gt;✅ 交付物:&lt;br&gt;• 回顾会议纪要&lt;br&gt;• 改进行动计划" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFEBE9;strokeColor=#795548;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="900" y="690" width="240" height="230" as="geometry" />
        </mxCell>
        
        <!-- ========== 连接线 ========== -->
        <mxCell id="conn1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="phase1-config" target="phase2-story">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="475" y="350" />
              <mxPoint x="190" y="350" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="conn2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="phase2-task" target="phase3-dev">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="750" y="670" />
              <mxPoint x="750" y="690" />
              <mxPoint x="180" y="690" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="conn3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="phase3-cr" target="phase4-test">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="445" y="865" />
              <mxPoint x="445" y="865" />
              <mxPoint x="445" y="330" />
              <mxPoint x="740" y="330" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="conn4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="phase4-bug" target="phase5-release">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1010" y="330" />
              <mxPoint x="1020" y="330" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="conn5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="phase5-release" target="phase5-retro">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- ========== 看板区域 ========== -->
        <mxCell id="kanban-header" value="&lt;b&gt;📋 Jira 看板配置&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#667eea;strokeColor=#5a67d8;fontColor=#ffffff;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="580" y="750" width="300" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="kanban-content" value="&lt;b&gt;标准列配置:&lt;/b&gt;&lt;br&gt;Backlog | To Do | In Progress | Code Review | Testing | Done&lt;br&gt;&lt;br&gt;&lt;b&gt;WIP Limits:&lt;/b&gt;&lt;br&gt;• In Progress: 每人2个&lt;br&gt;• Code Review: 每人3个&lt;br&gt;&lt;br&gt;&lt;b&gt;快速过滤器:&lt;/b&gt;&lt;br&gt;• 我的任务: assignee = currentUser()&lt;br&gt;• 当前Sprint: sprint in openSprints()&lt;br&gt;• 高优先级: priority in (High, Highest)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF2FF;strokeColor=#667eea;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="800" width="300" height="170" as="geometry" />
        </mxCell>
        
        <!-- ========== 说明区域 ========== -->
        <mxCell id="note" value="&lt;b&gt;💡 关键成功因素&lt;/b&gt;&lt;br&gt;• 所有Commit必须包含Jira ID&lt;br&gt;• Jira状态必须与实际进度一致&lt;br&gt;• Story Points ≤ 8，Task ≤ 8小时&lt;br&gt;• 每个Story必须有3+验收标准&lt;br&gt;• Bug严重程度决定响应时间&lt;br&gt;• Sprint预留20% Buffer&lt;br&gt;• 代码审查100%覆盖" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#FBC02D;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="70" width="220" height="180" as="geometry" />
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
